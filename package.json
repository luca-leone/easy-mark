{
  "name": "@easy-mark/cli",
  "version": "1.0.3",
  "private": false,
  "type": "module",
  "description": "Lightweight CLI to compile, sanitise, preview, and export Markdown directories as HTML and PDFs.",
  "license": "MIT",
  "bin": {
    "easy-mark": "bin/easy-mark.mjs"
  },
  "files": [
    "bin/",
    "core/server/",
    "core/web/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luca-leone/easy-mark.git"
  },
  "bugs": {
    "url": "https://github.com/luca-leone/easy-mark/issues"
  },
  "homepage": "https://github.com/luca-leone/easy-mark#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "markdown",
    "cli",
    "documentation",
    "pdf",
    "mermaid",
    "chartjs",
    "sanitised",
    "preview"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "commit:validate": "node script/git/validate-commit-message.mjs",
    "task:commit": "node script/git/auto-task-commit.mjs",
    "hooks:install": "node script/git/install-hooks.mjs",
    "validate:agentic-workflow": "node script/validate-agentic-workflow.mjs",
    "validate:agentic-workflow-events": "node script/agentic-workflow-runtime.mjs validate-contract",
    "validate:agentic-paths": "node script/validate-agentic-paths.mjs",
    "validate:agentic-runtime-contract": "node script/validate-agentic-lean-path-runtime.mjs",
    "validate:versioning": "node script/versioning-runtime.mjs validate-contract",
    "workflow:status": "node script/agentic-workflow-runtime.mjs status",
    "pack:dry-run": "node script/versioning-runtime.mjs pack-check && npm pack --dry-run",
    "validate:resource-budgets": "node script/validate-resource-budgets.mjs",
    "validate:markdown-governance": "node script/validate-markdown-governance.mjs",
    "repair:markdown-governance": "node script/repair-markdown-governance.mjs",
    "validate:governance": "node script/validate-governance.mjs",
    "report:agentic-compliance": "node script/report-agentic-compliance.mjs",
    "test:node": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "test": "npm run validate:governance && npm run test:node",
    "check": "npm test"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "github-slugger": "^2.0.0",
    "mem-fs": "^4.1.0",
    "mem-fs-editor": "^11.1.4",
    "mime-types": "^2.1.35",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "chart.js": "^4.5.1",
    "mermaid": "^11.15.0",
    "playwright": "^1.0.0",
    "playwright-core": "^1.0.0"
  },
  "devDependencies": {
    "chart.js": "^4.5.1",
    "mermaid": "^11.15.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "playwright-core": {
      "optional": true
    }
  }
}
