{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-use-agentic-workflow.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking agentic workflow state"
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-use-agentic-lean-path.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking agentic lean path contract"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-use-agentic-workflow.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking agentic workflow state"
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-use-agentic-lean-path.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking agentic lean path contract"
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-use-markdown-governance.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking markdown governance contract"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/user-prompt-submit-agentic-workflow.mjs\"",
            "timeout": 30,
            "statusMessage": "Starting agentic workflow intake"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/subagent-start-agentic-workflow.mjs\"",
            "timeout": 30,
            "statusMessage": "Recording agentic workflow subagent start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/subagent-stop-agentic-workflow.mjs\"",
            "timeout": 30,
            "statusMessage": "Recording agentic workflow subagent completion"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-agentic-workflow.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking agentic workflow completion"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/post-tool-use-agentic-lean-path.mjs\"",
            "timeout": 30,
            "statusMessage": "Recording agentic lean path compliance"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/post-tool-use-agentic-lean-path.mjs\"",
            "timeout": 30,
            "statusMessage": "Recording agentic lean path compliance"
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/post-tool-use-markdown-governance.mjs\"",
            "timeout": 30,
            "statusMessage": "Recording markdown governance compliance"
          }
        ]
      }
    ]
  }
}
