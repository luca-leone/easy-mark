{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-use-agentic-contract.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking agentic runtime contract"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-use-agentic-contract.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking agentic runtime contract"
          }
        ]
      }
    ]
  }
}
